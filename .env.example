# Server Configuration
PORT=3000
NODE_ENV=production

# HTTPS Configuration (leave empty to use HTTP only)
# Generate self-signed cert: openssl req -nodes -new -x509 -keyout key.pem -out cert.pem -days 365
HTTPS_ENABLED=true
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem

# Target Servers Configuration
# Path to the JSON file containing target server mappings
TARGETS_CONFIG=targets.json
# Default target to use when no query parameter is provided
DEFAULT_TARGET=default
# Query parameter name to specify target server (e.g., ?target=server1)
TARGET_QUERY_PARAM=target

# OAuth API Configuration
OAUTH_VALIDATION_URL=https://your-oauth-api.com/validate
# Optional: If OAuth API requires credentials
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Cache Configuration
CACHE_TTL_SECONDS=300
CACHE_CHECK_PERIOD_SECONDS=60

# Security
# Comma-separated list of allowed origins for CORS (or * for all)
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=combined
